---
import BaseLayout from "../layouts/BaseLayout.astro";
import CategoryCard from "../components/CategoryCard.astro";
import {
  CATEGORIES,
  CATEGORY_DISPLAY,
  CATEGORY_DESCRIPTION,
  type CategorySlug,
} from "../content.config.ts";
import { buildWikiTree, descendantsOf, urlFor } from "../lib/tree.ts";

const tree = await buildWikiTree();
const articles = tree.entries;

// Every descendant counts towards the category total so nested pages
// (e.g. "turk-tarihi/osmanli/ikinci-mehmed") are reflected in the card.
const countsByCategory = Object.fromEntries(
  CATEGORIES.map((c) => [c, descendantsOf(tree, c, false).length])
) as Record<CategorySlug, number>;

// Exclude the 9 top-level category root pages from "recently added" — they
// are structural pages rather than article content.
const recent = articles
  .filter((e) => e.id.includes("/"))
  .slice()
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 6);
---

<BaseLayout
  title="Türk Güncesi Wiki"
  description="Türk kültürü, tarihi, edebiyatı, sanatı, müziği, dili, mutfağı ve mimarisi üzerine açık, ücretsiz ve katkıya açık bir ansiklopedik başvuru kaynağı."
>
  <section class="hero">
    <div class="container">
      <h1 class="hero__title">Türk kültürünün açık ansiklopedisi</h1>
      <p class="hero__lead">
        Türk kültürüne adanmış açık bir wiki. Edebiyat, tarih ve müzik
        başta olmak üzere birçok alanda binlerce konuyu kaynaklarıyla beraber
        bir araya getiriyoruz.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-title">
        <h2>Kategoriler</h2>
        <a href="/wiki/">Tüm makaleleri gör →</a>
      </div>
      <div class="card-grid">
        {CATEGORIES.map((slug) => (
          <CategoryCard
            slug={slug}
            title={CATEGORY_DISPLAY[slug]}
            description={CATEGORY_DESCRIPTION[slug]}
            count={countsByCategory[slug]}
          />
        ))}
      </div>
    </div>
  </section>

  {recent.length > 0 && (
    <section class="section" style="background: var(--color-bg-subtle); border-block: 1px solid var(--color-border);">
      <div class="container">
        <div class="section-title">
          <h2>Son eklenen makaleler</h2>
          <a href="/wiki/">Arşiv →</a>
        </div>
        <ul class="article-list article-list--grid">
          {recent.map((entry) => {
            const cat = entry.id.split("/")[0];
            return (
              <li class="article-card">
                <div class="article-card__meta">
                  <span>{CATEGORY_DISPLAY[cat as CategorySlug] ?? cat}</span>
                  <time datetime={entry.data.date.toISOString()}>
                    {new Intl.DateTimeFormat("tr-TR", {
                      day: "numeric",
                      month: "short",
                      year: "numeric",
                    }).format(entry.data.date)}
                  </time>
                </div>
                <a href={urlFor(entry.id)}>{entry.data.title}</a>
                <p class="article-card__desc">{entry.data.description}</p>
              </li>
            );
          })}
        </ul>
      </div>
    </section>
  )}
</BaseLayout>
