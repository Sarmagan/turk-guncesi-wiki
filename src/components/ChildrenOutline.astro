---
import type { WikiNode, WikiTree } from "../lib/tree.ts";
import { urlFor, resolveCanonicalNodeId } from "../lib/tree.ts";

export interface Props {
  nodes: WikiNode[];
  heading?: string;
  /** When set, article links target the canonical URL for aliased entries. */
  tree?: WikiTree;
}

const { nodes, heading = "Bu bölümdeki alt sayfalar", tree } = Astro.props;

function hrefForNode(n: WikiNode): string {
  const id =
    tree && n.entry ? resolveCanonicalNodeId(tree, n.id) : n.id;
  return urlFor(id);
}
---

{nodes.length > 0 && (
  <section class="children-outline" aria-labelledby="children-outline-heading">
    <h2 id="children-outline-heading">{heading}</h2>
    <ul class="children-outline__list">
      {nodes.map((n) => (
        <li>
          <a href={hrefForNode(n)}>
            <span class="children-outline__title">{n.title}</span>
            {n.entry?.data.description && (
              <span class="children-outline__desc">
                {n.entry.data.description}
              </span>
            )}
          </a>
          {n.children.length > 0 && (
            <span class="children-outline__count" aria-label={`${n.children.length} alt sayfa`}>
              {n.children.length} alt sayfa
            </span>
          )}
        </li>
      ))}
    </ul>
  </section>
)}
