---
export interface Props {
  placeholder?: string;
  autofocus?: boolean;
}

const { placeholder = "Ara…", autofocus = false } = Astro.props;
---

<form class="searchbar" role="search" method="get" action="/ara/">
  <label class="visually-hidden" for="q">Arama</label>
  <input
    id="q"
    name="q"
    type="search"
    placeholder={placeholder}
    autocomplete="off"
    inputmode="search"
    autofocus={autofocus}
  />
  <button type="submit" class="searchbar__icon" aria-label="Ara">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="11" cy="11" r="7"/>
      <path d="m21 21-4.3-4.3"/>
    </svg>
  </button>
</form>
