---
import { CATEGORY_ICON, type CategorySlug } from "../content.config.ts";

export interface Props {
  slug: CategorySlug;
}

const { slug } = Astro.props;
const iconName = CATEGORY_ICON[slug];
---

{iconName === "book-open" && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M2 5a2 2 0 0 1 2-2h6v16H4a2 2 0 0 1-2-2V5Z"/>
    <path d="M14 3h6a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2h-6V3Z"/>
    <path d="M6 7h2M6 11h2M16 7h2M16 11h2"/>
  </svg>
)}

{iconName === "campfire" && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 3c1.5 2.5 3 4 3 6.5a3 3 0 0 1-6 0C9 7 10.5 5.5 12 3Z"/>
    <path d="M4 20l16-4M4 16l16 4"/>
  </svg>
)}

{iconName === "flag" && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M5 21V4"/>
    <path d="M5 4h11l-2 4 2 4H5"/>
  </svg>
)}

{iconName === "music" && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M9 18V5l12-2v13"/>
    <circle cx="6" cy="18" r="3"/>
    <circle cx="18" cy="16" r="3"/>
  </svg>
)}

{iconName === "scroll" && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M8 21h11a2 2 0 0 0 2-2v-2h-5"/>
    <path d="M19 17V5a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v2h5"/>
    <path d="M3 7h6v12a2 2 0 0 1-4 0V9"/>
  </svg>
)}

{iconName === "letter" && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M5 20V8l7-5 7 5v12"/>
    <path d="M9 20v-8h6v8"/>
  </svg>
)}

{iconName === "columns" && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M4 21h16"/>
    <path d="M4 3h16"/>
    <path d="M6 3v18M12 3v18M18 3v18"/>
    <path d="M4 6h16M4 18h16"/>
  </svg>
)}

{iconName === "bowl" && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M3 11h18a9 9 0 0 1-18 0Z"/>
    <path d="M12 3c-1.5 1.5-1.5 3 0 4.5S13.5 10.5 12 12"/>
  </svg>
)}

{iconName === "palette" && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 3a9 9 0 1 0 0 18c1 0 1.5-.5 1.5-1.3 0-.9-.7-1.3-.7-2.1 0-.9.7-1.6 1.6-1.6H16a5 5 0 0 0 5-5 8 8 0 0 0-9-8Z"/>
    <circle cx="7.5" cy="10.5" r="1"/>
    <circle cx="10.5" cy="7" r="1"/>
    <circle cx="15" cy="7" r="1"/>
    <circle cx="17.5" cy="10.5" r="1"/>
  </svg>
)}
