---
import type { WikiNode, WikiTree } from "../lib/tree.ts";
import { urlFor, resolveCanonicalNodeId } from "../lib/tree.ts";

export interface Props {
  node: WikiNode;
  tree: WikiTree;
  depth?: number;
  maxDepth?: number;
}

const { node, tree, depth = 0, maxDepth = 6 } = Astro.props;
const children = node.children
  .map((cid) => tree.byId.get(cid)!)
  .filter(Boolean);
const showChildren = depth < maxDepth && children.length > 0;
const linkTargetId = node.entry
  ? resolveCanonicalNodeId(tree, node.id)
  : node.id;
---

<li>
  <a href={urlFor(linkTargetId)} class="tree__title">{node.title}</a>
  {node.entry?.data.description && (
    <span class="tree__desc">{node.entry.data.description}</span>
  )}
  {showChildren && (
    <ul class="tree tree--nested">
      {children.map((child) => (
        <Astro.self node={child} tree={tree} depth={depth + 1} maxDepth={maxDepth} />
      ))}
    </ul>
  )}
</li>
