---
import CategoryIcon from "./CategoryIcon.astro";
import type { CategorySlug } from "../content.config.ts";
import { urlFor } from "../lib/tree.ts";

export interface Props {
  slug: CategorySlug;
  title: string;
  description: string;
  count: number;
}

const { slug, title, description, count } = Astro.props;
---

<a href={urlFor(slug)} class="category-card">
  <span class="category-card__icon" aria-hidden="true">
    <CategoryIcon slug={slug} />
  </span>
  <h3 class="category-card__title">{title}</h3>
  <p class="category-card__desc">{description}</p>
  <span class="category-card__count">
    {count} {count === 1 ? "makale" : "makale"}
  </span>
</a>
